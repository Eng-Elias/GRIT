# GRIT - Git Repo Intelligence Tool
# Copy this file to .env and fill in your values

# GitHub personal access token (optional, increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# Redis connection URL
REDIS_URL=redis://localhost:6379

# NATS connection URL
NATS_URL=nats://localhost:4222

# HTTP server port
PORT=8080

# Directory for disk-based repository clones
CLONE_DIR=/tmp/grit-clones

# Repos larger than this (in KB) use disk clone instead of in-memory
CLONE_SIZE_THRESHOLD_KB=51200
