# GRIT - Git Repo Intelligence Tool
# Copy this file to .env and fill in your values

# GitHub API — optional for public repos, strongly recommended
# (unauthenticated: 60 req/h, authenticated: 5,000 req/h)
GITHUB_TOKEN=ghp_...

# Gemini API — required for AI features
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Infrastructure
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# App
PORT=8080
LOG_LEVEL=info

# Directory for disk-based repository clones
CLONE_DIR=/tmp/grit-clones

# Repos larger than this (in KB) use disk clone instead of in-memory
CLONE_SIZE_THRESHOLD_KB=51200

# Cache TTLs (hours)
CACHE_TTL_CORE=24
CACHE_TTL_COMPLEXITY=24
CACHE_TTL_TEMPORAL=12
CACHE_TTL_CONTRIBUTOR=48
CACHE_TTL_AI_SUMMARY=1
CACHE_TTL_AI_HEALTH=6

# Analysis limits
MAX_COMMIT_HISTORY=5000
MAX_REPO_SIZE_MB=500
ANALYSIS_TIMEOUT_MINUTES=10
